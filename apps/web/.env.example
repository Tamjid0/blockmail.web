# ============================================
# Supabase Auth
# ============================================

# Cloud: https://your-project.supabase.co
# Self-hosted: http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=

# Cloud: Dashboard → Settings → API → anon public
# Self-hosted: Generated during Supabase setup
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloud: Dashboard → Settings → API → service_role secret
# Self-hosted: Generated during Supabase setup
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Database
# ============================================

# Cloud: Supabase Pooler (Transaction mode: port 6543)
# Self-hosted: postgresql://postgres:password@postgres:5432/blockmail
DATABASE_URL=

# ============================================
# Redis
# ============================================

# Cloud: Upstash REST URL
# Self-hosted: redis://redis:6379
REDIS_URL=

# ============================================
# Go Blockmail Engine
# ============================================

# Cloud: Railway/Fly.io URL
# Self-hosted: http://blockmail-engine:8080
BLOCKMAIL_ENGINE_URL=

# Shared secret for engine API authentication
BLOCKMAIL_ENGINE_API_KEY=

# ============================================
# App
# ============================================

# Cloud: https://blockmail.dev
# Self-hosted: http://your-vps-ip:3000
NEXT_PUBLIC_APP_URL=

# cloud | development | production
NODE_ENV=development
